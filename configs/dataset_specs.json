    {
      "name": "usc_had",
      "partition": "subject_trial",
      "window_size": 128,
      "window_stride": 64,
      "train_trials": [1, 2, 3],
      "val_trials": [4],
      "test_trials": [5],
      "include_val_in_train": false,
      "standardize": true,
      "min_client_samples": 20,
      "limit_clients": 14,
      "max_train_samples_per_client": 5000,
      "max_test_samples_per_client": 1000,
      "tag": "usc_had_subject_trialsplit_window128_stride64"
