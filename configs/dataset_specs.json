    {
      "name": "hhar",
      "partition": "user_windowed",
      "hhar_source": "watch",
      "client_mode": "user",
      "window_size": 128,
      "window_stride": 64,
      "strict_windows": false,
      "train_fraction": 0.7,
      "val_fraction": 0.1,
      "include_val_in_train": false,
      "resample_hz": 50.0,
      "standardize": true,
      "min_client_samples": 20,
      "limit_clients": 9,
      "max_train_samples_per_client": 5000,
      "max_test_samples_per_client": 1000,
      "tag": "hhar_watch_user_window128_stride64"
    },
    {
      "name": "femnist",
      "partition": "leaf_user",
      "standardize": false,
      "min_client_samples": 20,
      "client_selection": "seeded_random",
      "preserve_original_split": true,
      "limit_clients": 200,
      "tag": "femnist_c200_full"
    },
    {
      "name": "synthetic",
      "partition": "leaf_user",
      "standardize": false,
      "min_client_samples": 10,
      "limit_clients": 30,
      "tag": "leaf_synthetic_c30_full"
    }
  ]
}
