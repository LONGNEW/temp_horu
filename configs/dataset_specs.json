{
  "source_repo": "../fisher_FL_hd_unzipped",
  "description": "Primary paper/main-experiment dataset configs extracted from the fisher_FL_hd_unzipped scripts.",
  "datasets": [
    {
      "name": "uci_har",
      "partition": "subject",
      "test_size": 0.3,
      "standardize": true,
      "min_client_samples": 10,
      "limit_clients": 30,
      "tag": "uci_har_all30"
    },
    {
      "name": "wisdm",
      "partition": "user",
      "test_size": 0.3,
      "standardize": true,
      "min_client_samples": 20,
      "limit_clients": 51,
      "max_train_samples_per_client": 5000,
      "max_test_samples_per_client": 1000,
      "wisdm_modality": "phone_accel",
      "tag": "wisdm_phone_accel_u51_t5000_v1000"
    },
    {
      "name": "isolet_raw",
      "partition": "dirichlet",
      "num_clients": 8,
      "alpha": 5.0,
      "test_size": 0.3,
      "standardize": true,
      "tag": "isolet_raw_c8_full"
    },
    {
      "name": "ninapro_db1",
      "partition": "subject",
      "root": "data/tiers/on_device_hdc/ninapro_db1",
      "test_size": 0.3,
      "standardize": true,
      "min_client_samples": 20,
      "limit_clients": 27,
      "max_train_samples_per_client": 5000,
      "max_test_samples_per_client": 1000,
      "tag": "ninapro_db1_c27_t5000_v1000"
    },
    {
      "name": "emnist",
      "partition": "dirichlet",
