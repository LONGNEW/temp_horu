      "num_clients": 100,
      "limit_clients": 100,
      "alpha": 0.5,
      "test_size": 0.3,
      "standardize": false,
      "download": true,
      "tag": "emnist_balanced_c100_full"
    },
    {
      "name": "flamby_tcga_brca",
      "partition": "center",
      "num_clients": 100,
      "limit_clients": 100,
      "alpha": 0.5,
      "test_size": 0.3,
      "standardize": true,
      "min_client_samples": 1,
      "preserve_native_clients": true,
      "auto_accept_license": true,
      "tag": "flamby_tcga_brca_event_native_center_full"
    },
    {
      "name": "flamby_heart_disease",
      "partition": "center",
      "num_clients": 100,
      "limit_clients": 100,
      "alpha": 0.5,
      "test_size": 0.3,
      "standardize": true,
      "min_client_samples": 6,
      "preserve_native_clients": true,
      "auto_accept_license": true,
      "tag": "flamby_heart_disease_native_center_full"
    },
    {
      "name": "cifar10",
      "partition": "dirichlet",
      "num_clients": 100,
      "limit_clients": 100,
      "alpha": 0.5,
      "test_size": 0.3,
      "standardize": false,
      "tag": "cifar10_c100_full"
    },
    {
      "name": "cifar100",
      "label_type": "coarse",
      "partition": "dirichlet",
      "num_clients": 100,
      "limit_clients": 100,
      "alpha": 1.0,
      "test_size": 0.3,
      "standardize": false,
      "tag": "cifar100_coarse_c100_full"
    },
    {
      "name": "pamap2",
      "partition": "subject",
      "test_size": 0.3,
      "standardize": true,
      "min_client_samples": 20,
      "limit_clients": 8,
      "max_train_samples_per_client": 5000,
      "max_test_samples_per_client": 1000,
      "tag": "pamap2_c8_t5000_v1000"
    },
    {
      "name": "mhealth",
      "partition": "subject_windowed",
      "split_mode": "per_activity_chrono",
      "window_size": 128,
      "window_stride": 64,
      "strict_windows": false,
      "drop_ecg": true,
      "train_fraction": 0.7,
      "val_fraction": 0.1,
      "include_val_in_train": false,
      "standardize": true,
      "min_client_samples": 20,
      "limit_clients": 10,
      "max_train_samples_per_client": 5000,
      "max_test_samples_per_client": 1000,
      "tag": "mhealth_subject_window128_stride64_drop_ecg"
